/* pages/family-garden/family-tasks/index.wxss */

.container {
  padding: 40rpx;
  background-color: #f8f9fa;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 50%, #fecfef 100%);
  padding: 40rpx;
  border-radius: 24rpx;
  color: white;
  margin-bottom: 40rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 32rpx;
  opacity: 0.9;
}

.section-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #343a40;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 3rpx solid #ff9a9e;
}

/* 关怀提醒样式 */
.care-section {
  margin-bottom: 40rpx;
}

.care-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.care-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.care-card:active {
  transform: scale(0.98);
}

.care-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.care-content {
  flex: 1;
}

.care-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #343a40;
  margin-bottom: 8rpx;
}

.care-time {
  font-size: 28rpx;
  color: #6c757d;
}

.care-status {
  font-size: 40rpx;
  padding: 16rpx;
}

.care-status.completed {
  color: #28a745;
}

/* 健康监测样式 */
.health-section {
  margin-bottom: 40rpx;
}

.health-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.health-card {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.health-card:active {
  transform: scale(0.98);
}

.health-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.health-info {
  flex: 1;
  margin-bottom: 20rpx;
}

.health-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1976d2;
  margin-bottom: 8rpx;
  text-align: center;
}

.health-desc {
  font-size: 26rpx;
  color: #424242;
  text-align: center;
}

.health-action {
  text-align: center;
}

.action-btn {
  background: #1976d2;
  color: white;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 安全检查样式 */
.safety-section {
  margin-bottom: 40rpx;
}

.safety-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.safety-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.safety-item:active {
  transform: scale(0.98);
}

.safety-checkbox {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #dee2e6;
  border-radius: 50%;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: white;
  background: white;
  transition: all 0.3s ease;
}

.safety-checkbox.checked {
  background: #28a745;
  border-color: #28a745;
}

.safety-text {
  font-size: 32rpx;
  color: #343a40;
  flex: 1;
}

.safety-status {
  font-size: 32rpx;
  color: #6c757d;
  text-align: center;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

/* 社交互动样式 */
.social-section {
  margin-bottom: 40rpx;
}

.social-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.social-card {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.social-card:active {
  transform: scale(0.98);
}

.social-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.social-content {
  flex: 1;
}

.social-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #7b1fa2;
  margin-bottom: 8rpx;
  text-align: center;
}

.social-desc {
  font-size: 26rpx;
  color: #424242;
  text-align: center;
}

/* 紧急联系样式 */
.emergency-section {
  margin-bottom: 40rpx;
}

.emergency-contacts {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.contact-item:active {
  transform: scale(0.98);
}

.contact-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f44336;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.contact-info {
  flex: 1;
}

.contact-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #c62828;
  margin-bottom: 8rpx;
}

.contact-relation {
  font-size: 28rpx;
  color: #6c757d;
}

.contact-phone {
  font-size: 36rpx;
  font-weight: 600;
  color: #c62828;
  padding: 16rpx 24rpx;
  background: white;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}