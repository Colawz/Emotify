<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info">
      <!-- 头像选择按钮 -->
      <button class="avatar-wrapper" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image class="avatar" src="{{avatarUrl}}"></image>
      </button>
      <view class="user-detail">
        <!-- 昵称输入框 -->
        <form bindsubmit="onSubmitUserInfo">
          <input 
            type="nickname" 
            class="nickname-input" 
            placeholder="请输入昵称" 
            value="{{nickName}}"
            bindinput="getName"  
         
          />
          <button 
            class="login-btn"
            form-type="submit"
          >授权登录</button>
        </form>
        <text class="user-id" wx:if="{{userInfo.userId}}">ID: {{userInfo.userId}}</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="function-list">
      <!-- 我的发布 -->
      <t-cell
        title="我的发布"
        left-icon="file"
        hover
        arrow
        bind:tap="navigateToMyPosts"
      />

      <!-- 我的收藏 -->
      <t-cell
        title="我的收藏"
        left-icon="star"
        hover
        arrow
        bind:tap="navigateToMyFavorites"
      />

      <!-- 我的消息 -->
      <t-cell
        title="我的消息"
        left-icon="chat"
        hover
        arrow
        bind:tap="navigateToMyMessages"
      >
        <t-tag slot="note" theme="warning" variant="light" wx:if="{{unreadCount > 0}}">
          {{unreadCount}}
        </t-tag>
      </t-cell>

      <!-- 设置 -->
      <t-cell
        title="设置"
        left-icon="setting"
        hover
        arrow
        bind:tap="navigateToSettings"
      />
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>版本 1.0.0</text>
  </view>
</view>