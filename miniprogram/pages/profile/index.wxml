<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info {{userInfo.openid ? 'logged-in' : 'not-logged-in'}}">
      <!-- 头像选择按钮 -->
      <button wx:if="{{!avatarUrl}}" class="avatar-wrapper" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        选择头像
      </button>
      <!-- 已选择的头像显示 -->
      <image wx:else class="avatar" src="{{avatarUrl}}"></image>
      
      <view class="user-detail {{userInfo.openid ? 'logged-in' : ''}}">
        <!-- 授权登录按钮 -->
        <view wx:if="{{!userInfo.openid}}" class="auth-login-section">
          <button 
            class="login-btn"
            bindtap="showAuthModal"
          >授权登录</button>
          <text class="login-hint">点击进行用户信息设置和授权</text>
        </view>
        <!-- 已输入的昵称显示 -->
        <view wx:else class="nickname-display">
          <text class="nickname-text">{{userInfo.nickName}}</text>
        </view>
        <text class="user-id" wx:if="{{userInfo.openid}}">ID: {{userInfo.openid}}</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="function-list">
      <!-- 我的发布 -->
      <t-cell
        title="我的发布"
        left-icon="file"
        hover
        arrow
        bind:tap="navigateToMyPosts"
      />

      <!-- 我的收藏 -->
      <t-cell
        title="我的收藏"
        left-icon="star"
        hover
        arrow
        bind:tap="navigateToMyFavorites"
      />

      <!-- 我的消息 -->
      <t-cell
        title="我的消息"
        left-icon="chat"
        hover
        arrow
        bind:tap="navigateToMyMessages"
      >
        <t-tag slot="note" theme="warning" variant="light" wx:if="{{unreadCount > 0}}">
          {{unreadCount}}
        </t-tag>
      </t-cell>

      <!-- 设置 -->
      <t-cell
        title="设置"
        left-icon="setting"
        hover
        arrow
        bind:tap="navigateToSettings"
      />
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>版本 1.0.0</text>
  </view>

  <!-- 授权登录弹窗 -->
  <view class="pop_root" wx:if="{{showAuthModal}}" bindtap="closeAuthModal">
    <view class="pop_content" catchtap="stopPropagation">
      <!-- 弹窗头部 -->
      <view class="modal-header">
        <text class="modal-title">授权登录</text>
        <view class="close-btn" bindtap="closeAuthModal">×</view>
      </view>
      
      <!-- 弹窗内容 -->
      <view class="modal-body">
        <!-- 用户信息编辑区域 -->
        <view class="user-edit-section">
          <view class="avatar-section">
            <text class="section-title">选择头像</text>
            <view class="avatar-options">
              <!-- 头像选择按钮 -->
              <button wx:if="{{!modalAvatarUrl}}" class="modal-avatar-wrapper" open-type="chooseAvatar" bind:chooseavatar="onModalChooseAvatar">
                <text class="avatar-placeholder">选择头像</text>
              </button>
              <!-- 已选择的头像显示 -->
              <button wx:else class="modal-avatar" open-type="chooseAvatar" bind:chooseavatar="onModalChooseAvatar">
                <image class="avatar-image" src="{{modalAvatarUrl}}"></image>
              </button>
            </view>
          </view>
          
          <view class="nickname-section">
            <text class="section-title">输入昵称</text>
            <input
              type="nickname" 
              class="modal-nickname-input" 
              placeholder="请输入昵称" 
              value="{{modalNickName}}"
              bindinput="onModalGetName"
              confirm-type="done"
            />
          </view>
        </view>
        

        
        <view class="auth-tips">
          <text class="tip-item">• 我们不会获取您的其他隐私信息</text>
          <text class="tip-item">• 您可以随时在设置中修改个人信息</text>
        </view>
      </view>
      
      <!-- 弹窗按钮 -->
      <view class="modal-footer">
        <button class="cancel-btn" bindtap="closeAuthModal">取消</button>
        <button class="confirm-btn" bindtap="confirmAuth">确认授权</button>
      </view>
    </view>
  </view>
</view>