.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0;
  width: 100%;
}

/* 搜索卡片 */
.search-card {
  padding: 24rpx 0;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  width: 100%;
}

.search-inner {
  padding: 0 24rpx;
}

/* 消息列表 */
.message-list {
  flex: 1;
  width: 100%;
}

.empty-tip {
  text-align: center;
  padding: 48rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 消息列表项 - 微信/QQ列表样式 */
.message-item {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
  width: 100%;
  box-sizing: border-box;
}

.avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
}

.badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  background-color: #e34d59;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
  font-weight: 500;
}

.message-content {
  flex: 1;
  overflow: hidden;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.message-preview {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.preview-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 个人信息提示 */
.profile-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background-color: #fff;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #f0f0f0;
}

.profile-tip text {
  color: #333;
} 