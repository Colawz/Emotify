.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.chat-list {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.loading {
  text-align: center;
  padding: 24rpx 0;
}

.message-item {
  display: flex;
  margin-bottom: 32rpx;
}

.message-item.self {
  flex-direction: row-reverse;
}

.avatar-wrapper {
  margin: 0 16rpx;
}

.message-content {
  max-width: 60%;
}

.message-bubble {
  padding: 20rpx;
  border-radius: 16rpx;
  background-color: #fff;
  word-break: break-all;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.self .message-bubble {
  background-color: #0052d9;
  color: #fff;
}

.message-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
  text-align: center;
}

.input-area {
  background-color: #fff;
  padding: 24rpx;
  border-top: 1rpx solid #eee;
}

.input-box {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
}

.message-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
}

.send-btn {
  padding: 0 16rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
} 