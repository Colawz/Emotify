<!--index.wxml-->
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    <view class="userinfo">
      <block wx:if="{{canIUseNicknameComp && !hasUserInfo}}">
        <button class="avatar-wrapper" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
          <image class="avatar" src="{{userInfo.avatarUrl}}"></image>
        </button>
        <view class="nickname-wrapper">
          <text class="nickname-label">昵称</text>
          <input type="nickname" class="nickname-input" placeholder="请输入昵称" bind:change="onInputChange" />
        </view>
      </block>
      <block wx:elif="{{!hasUserInfo}}">
        <button wx:if="{{canIUseGetUserProfile}}" bindtap="getUserProfile"> 获取头像昵称 </button>
        <view wx:else> 请使用2.10.4及以上版本基础库 </view>
      </block>
      <block wx:else>
        <image bindtap="bindViewTap" class="userinfo-avatar" src="{{userInfo.avatarUrl}}" mode="cover"></image>
        <text class="userinfo-nickname">{{userInfo.nickName}}</text>
      </block>
    </view>

    <!-- 功能卡片区域 -->
    <view class="function-cards">
      <view class="card-row">
        <view class="function-card" bindtap="navigateToDormMatching">
          <t-icon name="home" size="48rpx" />
          <text>宿舍匹配</text>
        </view>
        <view class="function-card" bindtap="navigateToCarpool">
          <t-icon name="car" size="48rpx" />
          <text>拼车匹配</text>
        </view>
      </view>
      <view class="card-row">
        <view class="function-card" bindtap="navigateToSports">
          <t-icon name="basketball" size="48rpx" />
          <text>运动匹配</text>
        </view>
        <view class="function-card" bindtap="navigateToCanteenReview">
          <t-icon name="shop" size="48rpx" />
          <text>工大点评</text>
        </view>
      </view>
      <view class="card-row">
        <view class="function-card" bindtap="navigateToCounseling">
          <t-icon name="service" size="48rpx" />
          <text>心理咨询</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
