/* miniprogram/pages/counseling/conversation/create/index.wxss */
.container {
  padding: 40rpx;
  background-color: #fff;
  min-height: 100vh;
  box-sizing: border-box;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 60rpx;
}

.form-item {
  margin-bottom: 50rpx;
}

.form-label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.form-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 20rpx;
}

.avatar-wrapper {
  padding: 0;
  background-color: transparent;
  border: none;
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto;
  /* 移除button的默认边框 */
  line-height: normal; 
}
.avatar-wrapper::after {
  border: none;
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid #eee;
}

.avatar-placeholder {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ccc;
}

.placeholder-icon {
  font-size: 100rpx;
  color: #ccc;
  font-weight: 200;
}

.input {
  border-bottom: 1rpx solid #eee;
  height: 88rpx;
  font-size: 32rpx;
}

.textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  background-color: #f8f8f8;
}

.submit-btn {
  background-color: #8e44ad;
  color: #fff;
  border-radius: 44rpx;
  margin-top: 40rpx;
  font-weight: bold;
} 