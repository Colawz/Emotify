/* miniprogram/pages/counseling/conversation/chat/index.wxss */
.chat-page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F8F9FA;
}

/* 1. 顶部角色展示区 */
.header {
  position: relative;
  width: 100%;
  height: 220rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-btn {
  position: absolute;
  top: 90rpx;
  left: 20rpx;
  z-index: 3;
  padding: 10rpx;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.counselor-info {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.counselor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
}

.counselor-name {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 2. 聊天消息区域 */
.messages-container {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
  /* 预留出整个底部容器的高度 */
  padding-bottom: 400rpx; 
}

.message-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 30rpx;
  max-width: 85%;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.message-bubble {
  padding: 20rpx 28rpx;
  border-radius: 36rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-all;
}

.counselor {
  justify-content: flex-start;
}

.counselor .avatar {
  margin-right: 20rpx;
}

.counselor .message-bubble {
  background-color: #FFFFFF;
  color: #333;
  border-top-left-radius: 8rpx;
}

.user {
  margin-left: auto;
  flex-direction: row-reverse;
}

.user .message-bubble {
  background-color: #8A32E8;
  color: #fff;
  border-top-right-radius: 8rpx;
}

.loading-indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
}
.loading-indicator .dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #ccc;
  margin: 0 8rpx;
  animation: loading-bounce 1.4s infinite ease-in-out both;
}
.loading-indicator .dot:nth-child(1) { animation-delay: -0.32s; }
.loading-indicator .dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes loading-bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1.0); }
}

/* 3. 底部图片展示和输入区 */
.bottom-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #F8F9FA;
  border-top: 1rpx solid #EFEFEF;
  display: flex;
  flex-direction: column;
}

/* 新增：角色与生成图片容器 */
.image-display-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-bottom: 1rpx solid #dee2e6;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 左侧角色形象 */
.character-image-box {
  width: 35%;
  padding-right: 15rpx;
  position: relative;
}

.character-avatar {
  width: 100%;
  height: 300rpx;
  border-radius: 20rpx;
  object-fit: cover;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  border: 3rpx solid rgba(255, 255, 255, 0.8);
  transition: transform 0.3s ease;
}

.character-avatar:hover {
  transform: scale(1.02);
}

/* 右侧AI生成图片 */
.generated-image-box {
  position: relative;
  width: 65%;
  height: 300rpx;
  background: linear-gradient(45deg, #f8f9fa, #e9ecef);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  border: 3rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
}

.generated-image-box:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
}

.generated-image-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
  cursor: pointer;
}

.generated-image-preview:hover {
  transform: scale(1.05);
}

.image-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #6c757d;
  font-size: 26rpx;
  background: linear-gradient(45deg, #f8f9fa, #e9ecef);
  position: relative;
}

.image-placeholder::before {
  content: '🎨';
  font-size: 60rpx;
  margin-bottom: 10rpx;
  opacity: 0.6;
}

.image-placeholder::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 80rpx;
  height: 80rpx;
  margin: -40rpx 0 0 -40rpx;
  border: 4rpx solid #dee2e6;
  border-radius: 50%;
  border-top-color: transparent;
  animation: placeholder-pulse 2s ease-in-out infinite;
}

@keyframes placeholder-pulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 0.8; transform: scale(1.1); }
}

.image-loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(45deg, rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.4));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4rpx);
}

.loading-text {
  color: #fff;
  font-size: 26rpx;
  margin-top: 20rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  border-top-color: #fff;
  animation: loading-spin 1s linear infinite;
}

@keyframes loading-spin {
  to { transform: rotate(360deg); }
}

/* 调整聊天消息区域的高度，因为图片区域移到了上面 */
.messages-container {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

/* 调整输入区域的样式 */
/* 输入和操作区整体容器样式 */
.input-area {
  display: flex; /* 使用弹性布局，使子元素横向排列 */
  align-items: center; /* 垂直居中对齐所有子元素 */
  padding: 10rpx; /* 四周内边距，保证内容不贴边 */
  background-color: #fff; /* 背景色为白色 */
  border-top: 1rpx solid #eee; /* 顶部边框，分隔上方内容 */
}

/* 操作按钮样式（如重聊、图片开关） */
.action-btn {
  padding: 10rpx 5rpx; /* 上下12rpx，左右5rpx的内边距，让按钮更紧凑 */
  font-size: 26rpx; /* 字体大小 */
  color: #555; /* 字体颜色 */
  background-color: #f0f0f0; /* 按钮背景色 */
  border-radius: 30rpx; /* 圆角，按钮更圆润 */
  text-align: center; /* 文字居中 */
  margin-right: 8rpx; /* 右侧间距，分隔多个按钮 */
  display: flex; /* 弹性布局，方便图标和文字横向排列 */
  align-items: center; /* 垂直居中内容 */
  justify-content: center; /* 水平居中内容 */
  gap: 6rpx; /* 图标与文字之间的间距 */
  transition: all 0.3s ease; /* 状态变化时平滑过渡 */
}

.action-btn.active {
  background-color: #4CAF50;
  color: #fff;
}

.action-btn:hover {
  opacity: 0.8;
}

.input-field {
  flex: 1;
  height: 72rpx;
  background-color: #f7f7f7;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #4CAF50; /* 绿色边框 */
  min-width: 0; /* 允许输入框收缩 */
}

/* 发送按钮样式 */
.send-btn {
  background-color: #8A32E8; /* 紫色背景，突出按钮 */
  color: #fff; /* 文字为白色，保证对比度 */
  border: none; /* 无边框，简洁美观 */
  border-radius: 36rpx; /* 圆角，按钮更圆润 */
  padding: 0 24rpx; /* 左右内边距，给按钮合适的宽度 */
  height: 72rpx; /* 按钮高度与输入框一致 */
  line-height: 72rpx; /* 文字垂直居中 */
  font-size: 28rpx; /* 字体大小适中，易读 */
  flex-shrink: 0; /* 防止按钮被压缩，始终保持固定宽度 */
  margin-left: 8rpx; /* 与输入框保持间距 */
  transition: all 0.3s ease; /* 状态变化时平滑过渡 */
}

.send-btn[disabled] {
  background-color: #d0d0d0; /* 更明显的灰色背景 */
  color: #999; /* 更清晰的灰色文字 */
  cursor: not-allowed; /* 禁用状态的鼠标样式 */
}

.send-btn:not([disabled]):active {
  background-color: #6A1B9A; /* 按下时的深紫色 */
  transform: scale(0.98); /* 轻微缩放效果 */
}