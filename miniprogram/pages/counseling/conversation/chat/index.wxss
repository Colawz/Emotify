/* miniprogram/pages/counseling/conversation/chat/index.wxss */
.chat-page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F8F9FA; /* 一个柔和的背景色 */
}

/* 1. 顶部角色展示区 */
.header {
  position: relative;
  width: 100%;
  height: 220rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-btn {
  position: absolute;
  top: 90rpx; /* 大致适配大部分机型的状态栏高度 */
  left: 20rpx;
  z-index: 3;
  padding: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.counselor-info {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.counselor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.counselor-name {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 2. 聊天消息区域 */
.messages-container {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
  padding-bottom: 120rpx; /* 为输入框留出空间 */
}

.message-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 30rpx;
  max-width: 85%;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.message-bubble {
  padding: 20rpx 28rpx;
  border-radius: 36rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-all;
}

/* AI角色的消息 */
.counselor {
  justify-content: flex-start;
}

.counselor .avatar {
  margin-right: 20rpx;
}

.counselor .message-bubble {
  background-color: #FFFFFF;
  color: #333;
  border-top-left-radius: 8rpx;
}

/* 用户消息 */
.user {
  margin-left: auto; /* 关键：让整行靠右 */
  flex-direction: row-reverse;
}

.user .avatar {
  margin-left: 20rpx;
}

.user .message-bubble {
  background-color: #8A32E8; /* 一个疗愈系的紫色 */
  color: #fff;
  border-top-right-radius: 8rpx;
}

/* 加载中动画 */
.loading-indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
}
.loading-indicator .dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #ccc;
  margin: 0 8rpx;
  animation: loading-bounce 1.4s infinite ease-in-out both;
}
.loading-indicator .dot:nth-child(1) { animation-delay: -0.32s; }
.loading-indicator .dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes loading-bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1.0); }
}

/* 3. 底部输入和操作区 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #EFEFEF;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  color: #555;
  background-color: #f0f0f0;
  border-radius: 30rpx;
  text-align: center;
}

.input-field {
  flex: 1;
  height: 72rpx;
  background-color: #f7f7f7;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.send-btn {
  background-color: #8A32E8;
  color: #fff;
  border: none;
  border-radius: 36rpx;
  padding: 0 30rpx;
  height: 72rpx;
  line-height: 72rpx; /* 垂直居中 */
  font-size: 28rpx;
  margin-left: auto;
}

.send-btn[disabled] {
  background-color: #c8a2ef;
  color: #fff;
} 