/* miniprogram/pages/counseling/conversation/chat/index.wxss */
.chat-page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F8F9FA;
}

/* 1. 顶部角色展示区 */
.header {
  position: relative;
  width: 100%;
  height: 220rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-btn {
  position: absolute;
  top: 90rpx;
  left: 20rpx;
  z-index: 3;
  padding: 10rpx;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.counselor-info {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.counselor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
}

.counselor-name {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 2. 聊天消息区域 */
.messages-container {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
  /* 预留出整个底部容器的高度 */
  padding-bottom: 400rpx; 
}

.message-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 30rpx;
  max-width: 85%;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.message-bubble {
  padding: 20rpx 28rpx;
  border-radius: 36rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-all;
}

.counselor {
  justify-content: flex-start;
}

.counselor .avatar {
  margin-right: 20rpx;
}

.counselor .message-bubble {
  background-color: #FFFFFF;
  color: #333;
  border-top-left-radius: 8rpx;
}

.user {
  margin-left: auto;
  flex-direction: row-reverse;
}

.user .message-bubble {
  background-color: #8A32E8;
  color: #fff;
  border-top-right-radius: 8rpx;
}

.loading-indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
}
.loading-indicator .dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #ccc;
  margin: 0 8rpx;
  animation: loading-bounce 1.4s infinite ease-in-out both;
}
.loading-indicator .dot:nth-child(1) { animation-delay: -0.32s; }
.loading-indicator .dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes loading-bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1.0); }
}

/* 3. 底部图片展示和输入区 */
.bottom-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #F8F9FA;
  border-top: 1rpx solid #EFEFEF;
  display: flex;
  flex-direction: column;
}

/* 新增：角色与生成图片容器 */
.image-display-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f0f2f5; /* 更柔和的背景色 */
  border-bottom: 1rpx solid #e0e0e0;
}

/* 左侧角色形象 */
.character-image-box {
  width: 35%; /* 占据较小空间 */
  padding-right: 10rpx; /* 与右侧保持间距 */
}

.character-avatar {
  width: 100%;
  height: 300rpx; /* 固定高度 */
  border-radius: 16rpx;
  object-fit: cover;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 右侧AI生成图片 */
.generated-image-box {
  position: relative;
  width: 65%; /* 占据较大空间 */
  height: 300rpx;
  background-color: #e9ecef;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.generated-image-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #999;
  font-size: 28rpx;
  background-color: #f5f5f5;
}

.image-loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  color: #fff;
  font-size: 28rpx;
}

/* 调整聊天消息区域的高度，因为图片区域移到了上面 */
.messages-container {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

/* 调整输入区域的样式 */
.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #eee;
}

.action-btn {
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  color: #555;
  background-color: #f0f0f0;
  border-radius: 30rpx;
  text-align: center;
}

.input-field {
  flex: 1;
  height: 72rpx;
  background-color: #f7f7f7;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #4CAF50; /* 绿色边框 */
  min-width: 0; /* 允许输入框收缩 */
}

.send-btn {
  background-color: #2196F3; /* 蓝色背景 */
  color: #fff;
  border: none;
  border-radius: 36rpx;
  padding: 0 25rpx; /* 减小内边距 */
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  flex-shrink: 0; /* 防止按钮被压缩 */
}

.send-btn[disabled] {
  background-color: #a9d6f5;
  color: #e9ecef;
}