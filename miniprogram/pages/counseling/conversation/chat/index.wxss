/* miniprogram/pages/counseling/conversation/chat/index.wxss */
.chat-page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F8F9FA;
}

/* 1. 顶部角色展示区 */
.header {
  position: relative;
  width: 100%;
  height: 220rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-btn {
  position: absolute;
  top: 90rpx;
  left: 20rpx;
  z-index: 3;
  padding: 10rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.counselor-info {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.counselor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
}

.counselor-name {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 2. 聊天消息区域 */
.messages-container {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
  /* 预留出整个底部容器的高度 */
  padding-bottom: 400rpx; 
}

.message-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 30rpx;
  max-width: 85%;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.message-bubble {
  padding: 20rpx 28rpx;
  border-radius: 36rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-all;
}

.counselor {
  justify-content: flex-start;
}

.counselor .avatar {
  margin-right: 20rpx;
}

.counselor .message-bubble {
  background-color: #FFFFFF;
  color: #333;
  border-top-left-radius: 8rpx;
}

.user {
  margin-left: auto;
  flex-direction: row-reverse;
}

.user .message-bubble {
  background-color: #8A32E8;
  color: #fff;
  border-top-right-radius: 8rpx;
}

.loading-indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
}
.loading-indicator .dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #ccc;
  margin: 0 8rpx;
  animation: loading-bounce 1.4s infinite ease-in-out both;
}
.loading-indicator .dot:nth-child(1) { animation-delay: -0.32s; }
.loading-indicator .dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes loading-bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1.0); }
}

/* 3. 底部图片展示和输入区 */
.bottom-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #F8F9FA;
  border-top: 1rpx solid #EFEFEF;
  display: flex;
  flex-direction: column;
}

.image-display-box {
  position: relative;
  width: calc(100% - 40rpx);
  height: 300rpx;
  margin: 20rpx;
  border-radius: 12rpx;
  background-color: #e9ecef;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  border: 2rpx solid #F06292; /* 红色边框 */
}

.generated-image-preview {
  width: 100%;
  height: 100%;
}

.image-placeholder {
  color: #adb5bd;
  font-size: 28rpx;
}

.image-loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 10;
}

.loading-text {
  color: #fff;
  font-size: 28rpx;
}

.input-area {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  gap: 16rpx;
  background-color: #fff;
}

.action-btn {
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  color: #555;
  background-color: #f0f0f0;
  border-radius: 30rpx;
  text-align: center;
}

.input-field {
  flex: 1;
  height: 72rpx;
  background-color: #f7f7f7;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #4CAF50; /* 绿色边框 */
  min-width: 0; /* 允许输入框收缩 */
}

.send-btn {
  background-color: #2196F3; /* 蓝色背景 */
  color: #fff;
  border: none;
  border-radius: 36rpx;
  padding: 0 25rpx; /* 减小内边距 */
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  flex-shrink: 0; /* 防止按钮被压缩 */
}

.send-btn[disabled] {
  background-color: #a9d6f5;
  color: #e9ecef;
}