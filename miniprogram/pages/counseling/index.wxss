/* 顶部导航栏 */
.header {
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  padding: 40rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 50rpx;
  text-align: center;
}

.header-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #2c3e50;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.subtitle {
  font-size: 30rpx;
  color: #546e7a;
  margin-top: 16rpx;
  font-weight: 300;
}

.emergency-btn {
  background: linear-gradient(135deg, #9c26b0 0%, #e91e63 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(156, 38, 176, 0.3);
  margin-top: 20rpx;
}

/* 主要内容区 */
.container {
  padding: 40rpx;
  background: linear-gradient(135deg, rgba(255, 182, 193, 0.3) 0%, rgba(173, 216, 230, 0.3) 100%);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 特色卡片区域 */
.cards-container {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  align-items: center;
  width: 100%;
  max-width: 600rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(15rpx);
  -webkit-backdrop-filter: blur(15rpx);
  padding: 50rpx 40rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease-in-out;
  width: 100%;
  max-width: 500rpx;
}

.feature-card:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.card-icon {
  font-size: 72rpx;
  margin-right: 30rpx;
  filter: drop-shadow(2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2));
}

.card-content {
  flex: 1;
  text-align: left;
}

.card-title {
  font-size: 38rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 12rpx;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.card-description {
  font-size: 28rpx;
  color: #546e7a;
  line-height: 1.4;
}

.card-arrow {
  font-size: 44rpx;
  color: #7f8c8d;
  margin-left: 20rpx;
  transition: transform 0.3s ease;
}

.feature-card:active .card-arrow {
  transform: translateX(10rpx);
}

.ai-card {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.3) 0%, rgba(139, 92, 246, 0.3) 100%);
  border: 2rpx solid rgba(99, 102, 241, 0.4);
}

.treehole-card {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.3) 0%, rgba(5, 150, 105, 0.3) 100%);
  border: 2rpx solid rgba(16, 185, 129, 0.4);
}

.game-card {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.3) 0%, rgba(220, 38, 38, 0.3) 100%);
  border: 2rpx solid rgba(245, 158, 11, 0.4);
}

.feature-card-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.feature-card-header {
  flex: 1;
}

.feature-card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2c3e50;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.feature-card-subtitle {
  font-size: 26rpx;
  color: #546e7a;
  margin-top: 8rpx;
}

.feature-card-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-card-actions {
  display: flex;
  gap: 16rpx;
}

.feature-card-actions t-button {
  flex: 1;
}

.section {
  margin-bottom: 48rpx;
  width: 100%;
  max-width: 600rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.section-more {
  font-size: 26rpx;
  color: #9c26b0;
  text-shadow: 1rpx 1rpx 2rpx rgba(156, 38, 176, 0.2);
}

/* 心理测试 */
.test-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
  width: 100%;
  max-width: 600rpx;
}

.test-card {
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(15rpx);
  -webkit-backdrop-filter: blur(15rpx);
  border-radius: 32rpx;
  padding: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease-in-out;
}

.test-card:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.test-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  font-size: 48rpx;
}

.bg-purple {
  background: rgba(156, 38, 176, 0.2);
  border: 2rpx solid rgba(156, 38, 176, 0.3);
}

.bg-blue {
  background: rgba(33, 150, 243, 0.2);
  border: 2rpx solid rgba(33, 150, 243, 0.3);
}

.bg-green {
  background: rgba(76, 175, 80, 0.2);
  border: 2rpx solid rgba(76, 175, 80, 0.3);
}

.bg-orange {
  background: rgba(255, 152, 0, 0.2);
  border: 2rpx solid rgba(255, 152, 0, 0.3);
}

.test-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.test-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

/* 咨询师卡片 */
.counselor-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.counselor-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.counselor-avatar-name {
  display: flex;
  align-items: center;
}

.counselor-name-title {
  margin-left: 16rpx;
}

.counselor-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.counselor-title {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

.counselor-tags {
  margin: 16rpx 0;
}

.counselor-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

/* 预约记录 */
.appointment-list t-cell {
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.appointment-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 8rpx;
}

.appointment-time,
.appointment-location {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.appointment-time t-icon,
.appointment-location t-icon {
  margin-right: 8rpx;
}

.appointment-status {
  color: #9c26b0;
  font-size: 26rpx;
  font-weight: 500;
}

/* 资源列表 */
.resource-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.resource-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  display: flex;
}

.resource-item t-image {
  width: 240rpx;
  height: 180rpx;
}

.resource-info {
  flex: 1;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
}

.resource-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.resource-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.resource-author {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.resource-tags {
  margin-top: auto;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* 搜索栏样式 */
.search-wrapper {
  margin-bottom: 24rpx;
}

/* 紧急求助 */
.emergency-banner {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 24rpx;
}

/* 底部导航栏 */
.tab-bar-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1000;
}

/* 底部导航栏样式 */
.t-tab-bar {
  position: fixed !important; /* 使用 !important 确保覆盖组件内部样式 */
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1000; /* 确保在最上层 */
  background-color: #fff; /* 根据需要设置背景色 */
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1); /* 可选：添加顶部阴影 */
  border-top: 1px solid rgba(0,0,0,0.05); /* 添加顶部边框 */
  height: 110rpx; /* 设置导航栏高度 */
  padding-bottom: env(safe-area-inset-bottom); /* 适配底部安全区域 */
}