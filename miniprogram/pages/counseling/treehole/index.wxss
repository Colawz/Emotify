/* pages/counseling/treehole/index.wxss */
.treehole-container {
  min-height: 100vh;
  background: linear-gradient(135deg, rgba(255, 182, 193, 0.3) 0%, rgba(173, 216, 230, 0.3) 100%);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding-bottom: calc(110rpx + env(safe-area-inset-bottom));
}

/* 背景图区域 */
.hero-section {
  position: relative;
  width: 100%;
  height: 160rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.3) 0%, rgba(118, 75, 162, 0.3) 100%);
  backdrop-filter: blur(15rpx);
  -webkit-backdrop-filter: blur(15rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  margin: 20rpx;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

/* 主内容区 - 居中显示 */
.hero-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 20rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 16rpx;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.hero-subtitle {
  font-size: 28rpx;
  color: #546e7a;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* 帖子列表 */
.post-list-container {
  padding: 24rpx;
  box-sizing: border-box;
  height: calc(100vh - 160rpx - 110rpx);
  margin-top: 0;
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 32rpx 32rpx 0 0;
}

.post-card {
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(15rpx);
  -webkit-backdrop-filter: blur(15rpx);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.post-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, rgba(102, 126, 234, 0.5) 0%, rgba(118, 75, 162, 0.5) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.post-card:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-avatar-wrapper {
  position: relative;
}

.emotion-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  padding: 2rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.post-user-info {
  flex: 1;
  margin-left: 20rpx;
}

.post-username {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 4rpx;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.post-time {
  font-size: 24rpx;
  color: #546e7a;
}

.post-content {
  font-size: 32rpx;
  color: #2c3e50;
  line-height: 1.8;
  margin-bottom: 20rpx;
  letter-spacing: 0.5rpx;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.custom-tag {
  background: rgba(255, 255, 255, 0.2) !important;
  backdrop-filter: blur(8rpx) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.4) !important;
  color: #2c3e50 !important;
  padding: 8rpx 20rpx !important;
  border-radius: 20rpx !important;
  font-size: 24rpx !important;
}

.post-actions {
  display: flex;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

.action-btn {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(8rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.action-btn:active {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(0.95);
}

.action-btn text {
  font-size: 26rpx;
  color: #546e7a;
  margin-left: 8rpx;
  font-weight: 500;
}

.action-btn.active {
  background: rgba(255, 71, 87, 0.15);
  border: 1rpx solid rgba(255, 71, 87, 0.3);
}

.action-btn.active text {
  color: #ff4757;
}

/* 评论区域 */
.comment-section {
  margin-top: 24rpx;
  position: relative;
}

.comment-divider {
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 2rpx;
  background: #e0e0e0;
  border-radius: 2rpx;
}

.comment {
  display: flex;
  padding: 16rpx 0;
}

.comment-content {
  flex: 1;
  margin-left: 16rpx;
  background: linear-gradient(135deg, #f9f9fb, #f5f5f7);
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  position: relative;
}

.comment-content::before {
  content: '';
  position: absolute;
  left: -10rpx;
  top: 16rpx;
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 10rpx 12rpx 10rpx 0;
  border-color: transparent #f9f9fb transparent transparent;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.comment-username {
  font-size: 26rpx;
  font-weight: 500;
  color: #667eea;
}

.comment-time {
  font-size: 22rpx;
  color: #b0b0b0;
}

.comment-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

/* 空列表状态 */
.empty-list {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  animation: swing 3s ease-in-out infinite;
}

@keyframes swing {
  0%, 100% {
    transform: rotate(-5deg);
  }
  50% {
    transform: rotate(5deg);
  }
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-subtitle {
  font-size: 26rpx;
  color: #999;
}

/* 发布按钮 */
.floating-btn {
  position: fixed;
  right: 40rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  width: 120rpx;
  height: 120rpx;
  z-index: 10;
}

.btn-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
  }
  50% {
    box-shadow: 0 8rpx 40rpx rgba(102, 126, 234, 0.6);
  }
  100% {
    box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
  }
}

.floating-btn:active .btn-inner {
  transform: scale(0.95);
}

/* 底部导航栏 */
.tab-bar-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9;
  background: #fff;
}