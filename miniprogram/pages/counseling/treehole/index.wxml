<!-- pages/counseling/treehole/index.wxml -->
<view class="treehole-container">
  <!-- 背景图区域 -->
  <view class="hero-section">
    <view class="hero-content">
      <text class="hero-title">情绪树洞</text>
      <text class="hero-subtitle">在这里，释放你的情绪，倾听彼此的心声</text>
    </view>
  </view>

  <!-- 帖子列表 -->
  <scroll-view 
    scroll-y 
    class="post-list-container"
    refresher-enabled="{{true}}"
    refresher-triggered="{{isRefreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
  >
    <block wx:if="{{postList.length > 0}}">
      <view class="post-card" wx:for="{{postList}}" wx:key="id" bindtap="onPostTap" data-id="{{item.id}}">
        <view class="post-header">
          <view class="post-avatar-wrapper">
            <t-avatar image="https://via.placeholder.com/40" size="medium" />
            <view class="emotion-badge">💭</view>
          </view>
          <view class="post-user-info">
            <view class="post-username">匿名用户</view>
            <view class="post-time">{{item.publishTime}}</view>
          </view>
          <t-icon name="more" size="48rpx" color="#b8b8b8" />
        </view>
        
        <view class="post-content">{{item.content}}</view>
        
        <view class="post-tags">
          <t-tag 
            wx:for="{{item.tags}}" 
            wx:for-item="tag" 
            wx:key="index" 
            class="custom-tag"
            variant="light"
            size="small"
          >
            <text>{{tag}}</text>
          </t-tag>
        </view>
        
        <view class="post-actions">
          <view 
            class="action-btn {{item.isLiked ? 'active' : ''}}" 
            catchtap="onLikeTap" 
            data-id="{{item.id}}" 
            data-index="{{index}}"
          >
            <t-icon name="{{item.isLiked ? 'heart-filled' : 'heart'}}" size="40rpx" />
            <text>{{item.likeCount}}</text>
          </view>
          <view class="action-btn" catchtap="onCommentTap" data-id="{{item.id}}">
            <t-icon name="chat" size="40rpx" />
            <text>{{item.commentCount}}</text>
          </view>
          <view class="action-btn" catchtap="onShareTap" data-id="{{item.id}}">
            <t-icon name="share" size="40rpx" />
          </view>
        </view>
        
        <!-- 评论区域 -->
        <view class="comment-section" wx:if="{{item.comments.length > 0}}">
          <view class="comment-divider"></view>
          <view class="comment" wx:for="{{item.comments}}" wx:for-item="comment" wx:key="id">
            <t-avatar image="https://via.placeholder.com/32" size="small" />
            <view class="comment-content">
              <view class="comment-header">
                <text class="comment-username">{{comment.username}}</text>
                <text class="comment-time">{{comment.time}}</text>
              </view>
              <view class="comment-text">{{comment.content}}</view>
            </view>
          </view>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="empty-list">
        <view class="empty-icon">🌳</view>
        <text class="empty-text">树洞里还没有心声</text>
        <text class="empty-subtitle">成为第一个倾诉者吧</text>
      </view>
    </block>
  </scroll-view>

  <!-- 发布按钮 -->
  <view class="floating-btn" bindtap="onPublishTap">
    <view class="btn-inner">
      <t-icon name="edit-1" size="48rpx" color="#fff" />
    </view>
  </view>
  
  <!-- 底部导航栏 -->
  <view class="tab-bar-container">
    <t-tab-bar value="{{currentTab}}" split="{{false}}" theme="tag" bindchange="onTabBarChange" fixed="{{true}}" style="--td-tab-bar-color: #999999; --td-tab-bar-active-color: #9c26b0;">
      <t-tab-bar-item value="ai-chat" icon="notification" label="AI助手" />
      <t-tab-bar-item value="discover" icon="view-module" label="发现" />
      <t-tab-bar-item value="message" icon="chat" label="消息" />
      <t-tab-bar-item value="profile" icon="user" label="我的" />
    </t-tab-bar>
  </view>
</view> 