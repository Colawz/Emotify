/* miniprogram/pages/counseling/diary/write/index.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f8f8f8;
  padding: 30rpx;
  box-sizing: border-box;
}

.prompt-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.prompt-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.prompt-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.input-area {
  flex: 1;
  width: 100%;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.save-btn {
  margin-top: 40rpx;
  background-image: linear-gradient(135deg, #a8e063, #56ab2f);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 20rpx rgba(86, 171, 47, 0.3);
}

.save-btn[disabled] {
  background-image: none;
  background-color: #ccc;
  box-shadow: none;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: #999;
} 