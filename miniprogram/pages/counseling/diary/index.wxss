/* miniprogram/pages/counseling/diary/index.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(135deg, rgba(255, 182, 193, 0.3) 0%, rgba(173, 216, 230, 0.3) 100%);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 60rpx;
  text-align: center;
  padding: 60rpx 40rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 52rpx;
  font-weight: bold;
  color: #2c3e50;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.subtitle {
  font-size: 28rpx;
  color: #546e7a;
  margin-top: 15rpx;
}

.categories-container {
  display: flex;
  flex-direction: column;
  padding: 0 40rpx;
  gap: 30rpx;
  width: 100%;
  max-width: 600rpx;
}

.category-card {
  color: #2c3e50;
  padding: 40rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(15rpx);
  -webkit-backdrop-filter: blur(15rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease-in-out;
}

.category-card:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.card-emoji {
  font-size: 72rpx;
  margin-right: 40rpx;
  filter: drop-shadow(2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2));
}

.card-content {
  flex: 1;
}

.card-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.card-description {
  font-size: 26rpx;
  line-height: 1.5;
  color: #546e7a;
}