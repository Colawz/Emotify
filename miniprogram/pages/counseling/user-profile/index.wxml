<view class="container">
  <view class="header">
    <view class="title">我的足迹</view>
    <view class="subtitle">这里收藏了你一路走来的点点滴滴</view>
  </view>

  <scroll-view scroll-y class="content-area">
    <!-- 活动统计图表 -->
    <view class="stats-card">
      <view class="stats-title">近期活动分析</view>
      <view class="chart-container">
        <view class="chart-bar" wx:for="{{activityStats}}" wx:key="id">
          <view class="bar-value">{{item.value}}</view>
          <view class="bar-fill" style="height: {{item.value}}%; background-color: {{item.color}};"></view>
          <view class="bar-label">{{item.label}}</view>
        </view>
      </view>
    </view>

    <block wx:if="{{isLoading}}">
      <view class="loading-container">
        <text>正在加载...</text>
      </view>
    </block>

    <block wx:elif="{{diaries.length > 0}}">
      <view class="diaries-list">
        <view 
          class="diary-card" 
          wx:for="{{diaries}}" 
          wx:key="id"
          bindtap="onDiaryTap"
          data-id="{{item.id}}"
        >
          <view class="card-header">
            <view class="card-topic">{{item.topic.title}}</view>
            <view class="card-time">{{item.displayTime}}</view>
          </view>
          <view class="card-content">
            {{item.content}}
          </view>
          <view class="card-footer">
            <text>点击查看详情</text>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="empty-container">
        <view class="empty-emoji">📝</view>
        <view class="empty-text">你还没有写过日记呢</view>
        <view class="empty-tip">快去记录下今天的心情吧！</view>
      </view>
    </block>
  </scroll-view>
</view> 