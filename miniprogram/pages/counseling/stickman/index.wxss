/* pages/counseling/stickman/index.wxss */
.game-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: linear-gradient(to bottom, #ff6b6b 0%, #ffa500 100%);
  overflow: hidden;
}

/* 游戏头部 */
.game-header {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: rgba(0, 0, 0, 0.8);
  z-index: 100;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.3);
}

.back-btn {
  color: #fff;
}

.game-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.stress-meter {
  display: flex;
  align-items: center;
}

.stress-label {
  font-size: 28rpx;
  color: #fff;
}

.stress-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #00ff00;
  margin-left: 8rpx;
}

/* 游戏画布 */
.game-canvas {
  position: absolute;
  top: 120rpx;
  left: 0;
  width: 100%;
  height: calc(100% - 240rpx);
  background: rgba(255, 255, 255, 0.1);
}

/* 武器选择栏 */
.weapon-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: rgba(0, 0, 0, 0.9);
  padding: 16rpx;
  z-index: 100;
}

.weapon-title {
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 8rpx;
  display: block;
}

.weapon-scroll {
  height: 80rpx;
  white-space: nowrap;
}

.weapon-list {
  display: inline-flex;
  gap: 16rpx;
}

.weapon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.weapon-item.active {
  background: rgba(255, 255, 255, 0.4);
  border-color: #00ff00;
  transform: scale(1.1);
}

.weapon-icon {
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.weapon-name {
  font-size: 20rpx;
  color: #fff;
  text-align: center;
}

/* 游戏说明 */
.game-instructions {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.8);
  z-index: 200;
}

.instruction-content {
  background: white;
  border-radius: 32rpx;
  padding: 60rpx;
  text-align: center;
  max-width: 600rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.instruction-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.instruction-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.instruction-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.instruction-tips {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 特效容器 */
.effects-container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 50;
}

.effect-item {
  position: absolute;
  transition: all 0.5s ease-out;
}

.effect-text {
  font-size: 32rpx;
  font-weight: bold;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

/* 重新开始按钮 */
.restart-btn {
  position: absolute;
  top: 140rpx;
  right: 32rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 60;
  border: 2rpx solid #fff;
}

.restart-btn:active {
  transform: scale(0.95);
} 