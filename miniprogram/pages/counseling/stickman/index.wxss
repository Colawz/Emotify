/* pages/counseling/stickman/index.wxss */
.game-container {
  position: relative;
  width: 100vw;
  height: calc(100vh - env(safe-area-inset-top));
  height: calc(100vh - constant(safe-area-inset-top)); /* iOS < 11.2 兼容 */
  background: linear-gradient(to bottom, #ff6b6b 0%, #ffa500 100%);
  overflow: hidden;
  /* 让整个容器从状态栏下面开始 */
  margin-top: env(safe-area-inset-top);
  margin-top: constant(safe-area-inset-top); /* iOS < 11.2 兼容 */
  box-sizing: border-box;
}

/* 游戏头部 */
.game-header {
  position: absolute;
  top: 70rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 90%;
  max-width: 750rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: rgba(0, 0, 0, 0.8);
  z-index: 100;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.3);
  border-radius: 16rpx;
}

.back-btn {
  color: #fff;
}

.game-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.stress-meter {
  display: flex;
  align-items: center;
}

.stress-label {
  font-size: 28rpx;
  color: #fff;
}

.stress-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #00ff00;
  margin-left: 8rpx;
}

/* 游戏画布 */
.game-canvas {
  position: absolute;
  top: 210rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 90%;
  max-width: 750rpx;
  height: calc(100% - 350rpx);
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
}

/* 武器选择栏 */
.weapon-bar {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 90%;
  max-width: 750rpx;
  height: 120rpx;
  background: rgba(0, 0, 0, 0.9);
  padding: 16rpx;
  z-index: 100;
  border-radius: 16rpx;
}

.weapon-title {
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 8rpx;
  display: block;
}

.weapon-scroll {
  height: 80rpx;
  white-space: nowrap;
}

.weapon-list {
  display: inline-flex;
  gap: 16rpx;
}

.weapon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.weapon-item.active {
  background: rgba(255, 255, 255, 0.4);
  border-color: #00ff00;
  transform: scale(1.1);
}

.weapon-icon {
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.weapon-name {
  font-size: 20rpx;
  color: #fff;
  text-align: center;
}

/* 游戏说明 */
.game-instructions {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.8);
  z-index: 200;
}

.instruction-content {
  background: white;
  border-radius: 32rpx;
  padding: 60rpx;
  text-align: center;
  max-width: 600rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.instruction-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.instruction-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.instruction-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.instruction-tips {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 特效显示 */
.effects-container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 50;
}

.effect-item {
  position: absolute;
  pointer-events: none;
  animation: effectFadeOut 1s ease-out forwards;
}

.effect-text {
  font-weight: bold;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.5);
  display: block;
  transform-origin: center;
}

/* 不同武器特效样式 */
.effect-item[data-size="normal"] .effect-text {
  font-size: 32rpx;
  animation: normalEffect 0.8s ease-out forwards;
}

.effect-item[data-size="large"] .effect-text {
  font-size: 40rpx;
  animation: largeEffect 1s ease-out forwards;
}

.effect-item[data-size="huge"] .effect-text {
  font-size: 48rpx;
  animation: hugeEffect 1.2s ease-out forwards;
}

.effect-item[data-size="sharp"] .effect-text {
  font-size: 36rpx;
  animation: sharpEffect 0.9s ease-out forwards;
}

.effect-item[data-size="sparkle"] .effect-text {
  font-size: 28rpx;
  animation: sparkleEffect 1.5s ease-out forwards;
}

.effect-item[data-size="particle"] .effect-text {
  font-size: 20rpx;
  animation: particleEffect 1s ease-out forwards;
}

.effect-item[data-size="shockwave"] .effect-text {
  font-size: 60rpx;
  animation: shockwaveEffect 0.5s ease-out forwards;
}

/* 特效动画 */
@keyframes normalEffect {
  0% {
    transform: scale(0.5) rotate(-10deg);
    opacity: 1;
  }
  50% {
    transform: scale(1.2) rotate(5deg);
    opacity: 0.9;
  }
  100% {
    transform: scale(1) rotate(0deg) translateY(-20rpx);
    opacity: 0;
  }
}

@keyframes largeEffect {
  0% {
    transform: scale(0.3) rotate(-15deg);
    opacity: 1;
  }
  30% {
    transform: scale(1.4) rotate(10deg);
    opacity: 1;
  }
  100% {
    transform: scale(1.1) rotate(0deg) translateY(-30rpx);
    opacity: 0;
  }
}

@keyframes hugeEffect {
  0% {
    transform: scale(0.2) rotate(-20deg);
    opacity: 1;
  }
  20% {
    transform: scale(1.6) rotate(15deg);
    opacity: 1;
  }
  40% {
    transform: scale(1.3) rotate(-5deg);
    opacity: 0.9;
  }
  100% {
    transform: scale(1.2) rotate(0deg) translateY(-40rpx);
    opacity: 0;
  }
}

@keyframes sharpEffect {
  0% {
    transform: scale(0.4) rotate(-30deg) skewX(-10deg);
    opacity: 1;
  }
  50% {
    transform: scale(1.3) rotate(15deg) skewX(5deg);
    opacity: 0.9;
  }
  100% {
    transform: scale(1) rotate(0deg) skewX(0deg) translateY(-25rpx);
    opacity: 0;
  }
}

@keyframes sparkleEffect {
  0% {
    transform: scale(0.3) rotate(0deg);
    opacity: 1;
    filter: brightness(1.5) blur(0rpx);
  }
  25% {
    transform: scale(1.2) rotate(90deg);
    opacity: 1;
    filter: brightness(2) blur(1rpx);
  }
  50% {
    transform: scale(0.8) rotate(180deg);
    opacity: 0.8;
    filter: brightness(1.8) blur(2rpx);
  }
  75% {
    transform: scale(1.1) rotate(270deg);
    opacity: 0.6;
    filter: brightness(1.5) blur(1rpx);
  }
  100% {
    transform: scale(0.9) rotate(360deg) translateY(-35rpx);
    opacity: 0;
    filter: brightness(1) blur(0rpx);
  }
}

@keyframes particleEffect {
  0% {
    transform: scale(1) rotate(0deg);
    opacity: 0.8;
  }
  50% {
    transform: scale(1.5) rotate(180deg);
    opacity: 0.6;
  }
  100% {
    transform: scale(0.5) rotate(360deg) translate(var(--random-x, 0), var(--random-y, -50rpx));
    opacity: 0;
  }
}

@keyframes shockwaveEffect {
  0% {
    transform: scale(0.1);
    opacity: 0.6;
  }
  50% {
    transform: scale(2);
    opacity: 0.3;
  }
  100% {
    transform: scale(4);
    opacity: 0;
  }
}

/* 发光效果 */
.effect-item[data-weapon-type="magic"] .effect-text {
  text-shadow: 
    0 0 10rpx currentColor,
    0 0 20rpx currentColor,
    0 0 30rpx currentColor,
    2rpx 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

/* 震动效果 */
.effect-item[data-weapon-type="fist"] .effect-text,
.effect-item[data-weapon-type="bat"] .effect-text,
.effect-item[data-weapon-type="hammer"] .effect-text {
  animation-timing-function: cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

/* 重新开始按钮 */
.restart-btn {
  position: absolute;
  top: 220rpx;
  right: 5%;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 60;
  border: 2rpx solid #fff;
}

.restart-btn:active {
  transform: scale(0.95);
}