<!-- pages/counseling/stickman/index.wxml -->
<view class="game-container">
  <!-- 顶部导航栏 -->
  <view class="game-header">
    <t-icon class="back-btn" name="chevron-left" size="48rpx" bind:click="onBackTap" />
    <text class="game-title">暴揍火柴人</text>
    <view class="stress-meter">
      <text class="stress-label">压力释放: </text>
      <text class="stress-value">{{stressRelief}}%</text>
    </view>
  </view>

  <!-- 游戏画布 -->
  <canvas 
    id="gameCanvas"
    type="2d"
    class="game-canvas"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  ></canvas>

  <!-- 武器选择栏 -->
  <view class="weapon-bar">
    <text class="weapon-title">选择武器:</text>
    <scroll-view scroll-x class="weapon-scroll">
      <view class="weapon-list">
        <view 
          wx:for="{{weapons}}" 
          wx:key="id"
          class="weapon-item {{selectedWeapon === item.id ? 'active' : ''}}"
          bindtap="selectWeapon"
          data-weapon="{{item.id}}"
        >
          <text class="weapon-icon">{{item.icon}}</text>
          <text class="weapon-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 游戏说明 -->
  <view class="game-instructions" wx:if="{{showInstructions}}">
    <view class="instruction-content">
      <view class="instruction-icon">◎</view>
      <text class="instruction-title">暴揍火柴人</text>
      <text class="instruction-desc">点击火柴人进行攻击，释放你的压力！</text>
      <text class="instruction-tips">选择不同武器体验不同的打击效果</text>
      <t-button theme="primary" size="large" shape="round" bind:tap="startGame">开始游戏</t-button>
    </view>
  </view>

  <!-- 特效显示 -->
  <view class="effects-container">
    <view 
      wx:for="{{effects}}" 
      wx:key="id"
      class="effect-item"
      style="left: {{item.x}}px; top: {{item.y}}px; opacity: {{item.opacity}}"
    >
      <text class="effect-text" style="color: {{item.color}}">{{item.text}}</text>
    </view>
  </view>

  <!-- 重新开始按钮 -->
  <view class="restart-btn" bindtap="restartGame" wx:if="{{!showInstructions}}">
    <t-icon name="refresh" size="40rpx" color="#fff" />
  </view>
</view> 