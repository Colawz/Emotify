/* pages/counseling/profile-analysis/index.wxss */
page {
  height: 100vh;
  overflow: hidden;
}

.container {
  background-color: #f8f8f8;
  position: relative;
  height: 100%;
}

/* 让下方区域成为剩余高度的可滚动区域（减去顶部雷达图高度）*/
.content-scroll {
  position: absolute;
  top: 580rpx; /* 500rpx 图高 + 2*40rpx 内边距 */
  bottom: 0;
  left: 0;
  right: 0;
}

.chart-wrapper {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
  background-color: #fff;
  margin: 0rpx 30rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.08);
}

/* 固定在页面上侧的样式（即使滚动，下方区域滚动，雷达图保持在顶部） */
.fixed-chart {
  position: fixed; /* 确保雷达图固定在顶部 */
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
}

.radar-chart {
  width: 500rpx;
  height: 500rpx;
}

.card {
  background-color: #fff;
  margin: 30rpx;
  padding: 40rpx;
  border-radius: 24rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  position: relative;
  padding-left: 20rpx;
}

.card-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 80%;
  background-color: #8A32E8;
  border-radius: 4rpx;
}

.card-content {
  font-size: 28rpx;
  line-height: 1.7;
  color: #555;
}

.dimensions-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.dimension-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
  color: #333;
}

.dimension-desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: #666;
} 

.strategy-card {
  padding: 20rpx;
  text-align: center;
}

.strategy-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}